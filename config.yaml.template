model:
  default: deepseek-v4-pro
  provider: llmgateway
  api_mode: chat_completions
  base_url: https://api.llmgateway.io/v1
  api_key: ${LLMGATEWAY_API_KEY}
  context_length: 128000
providers: {}
fallback_providers: []
credential_pool_strategies: {}
toolsets:
- delegation
- web
- skills
- memory
- session_search
- todo
- vision
- terminal
agent:
  max_turns: 90
  gateway_timeout: 1800
  restart_drain_timeout: 60
  api_max_retries: 3
  tool_use_enforcement: auto
  gateway_timeout_warning: 900
  clarify_timeout: 600
  gateway_notify_interval: 600
  gateway_auto_continue_freshness: 3600
  image_input_mode: auto
  disabled_toolsets:
  - code_execution
  - file-read
  - file-write
  - patch
  - search_files
  - messaging
  - tts
  - cronjob
  capabilities:
  - receives_from
  - discover
  - all
  description: "Balam — multi-agent coding assistant. Jaguar that delegates with precision."
  keep_alive: true
  launch_command: hermes acp
  name: balam
  role: balam
delegation:
  provider: llmgateway
  model: deepseek-v4-flash
  base_url: https://api.llmgateway.io/v1
  api_key: ${LLMGATEWAY_API_KEY}
  api_mode: chat_completions
  max_iterations: 50
  max_concurrent_children: 3
  max_spawn_depth: 2
  subagent_auto_approve: true
  inherit_mcp_toolsets: true
  orchestrator_enabled: true
  child_timeout_seconds: 600
auxiliary:
  vision:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 120
    extra_body: {}
    download_timeout: 30
  web_extract:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 360
    extra_body: {}
  compression:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 120
    extra_body: {}
  skills_hub:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 30
    extra_body: {}
  approval:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 30
    extra_body: {}
  mcp:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 30
    extra_body: {}
  title_generation:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 30
    extra_body: {}
  session_search:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 30
    extra_body: {}
    max_concurrency: 3
  flush_memories:
    provider: llmgateway
    model: deepseek-v4-flash
    base_url: https://api.llmgateway.io/v1
    api_key: ${LLMGATEWAY_API_KEY}
    timeout: 30
    extra_body: {}
mcp_servers:
  graphify:
    command: npx
    args:
    - "-y"
    - "graphifyy@latest"
    env:
      GRAPHIFY_BACKEND: openai
      GRAPHIFY_API_KEY: ${LLMGATEWAY_API_KEY}
      GRAPHIFY_BASE_URL: "https://api.llmgateway.io/v1"
      GRAPHIFY_MODEL: "deepseek-v4-flash"
terminal:
  backend: local
  cwd: .
  timeout: 180
memory:
  memory_enabled: true
  user_profile_enabled: true
  memory_char_limit: 4000
  user_char_limit: 3000
compression:
  enabled: true
  threshold: 0.80
  target_ratio: 0.20
  protect_last_n: 20
  hygiene_hard_message_limit: 300
  protect_first_n: 3
display:
  compact: false
  personality: none
  show_reasoning: true
  streaming: true
  show_cost: true
  language: en
timezone: America/Mexico_City

custom_providers:
- name: llmgateway
  base_url: https://api.llmgateway.io/v1
  api_key: ${LLMGATEWAY_API_KEY}
  api_mode: chat_completions
  models:
    deepseek-v4-pro:
      context_length: 262000
    deepseek-v4-flash:
      context_length: 262000
